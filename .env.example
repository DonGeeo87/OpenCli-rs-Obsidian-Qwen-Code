# ⚠️ ESTE ARCHIVO ES SOLO PLANTILLA
# ⚠️ NUNCA PONER API KEYS REALES AQUI
# ⚠️ Copia este archivo a .env y agrega tus keys reales

# Resend API Key (para envío de emails)
# Obtén tu key en: https://resend.com/api-keys
RESEND_API_KEY=re_tu_api_key_aqui

# Notion API Key
# Obtén tu key en: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_tu_api_key_aqui

# Configuración de Emails - Jess Vitrofusión
EMAIL_FROM=guerrerobritocarlos@gmail.com
EMAIL_CC=chicjessy@gmail.com
EMAIL_REPLY_TO=guerrerobritocarlos@gmail.com

# Sitio Web Oficial
WEBSITE=https://jessvitrofusion.art/

# WhatsApp para cotizaciones
WHATSAPP=+569XXXXXXXX

# Límites de Envío
EMAILS_POR_DIA=50
EMAILS_POR_ENVIO=2
INTERVALO_ENVIO_MINUTOS=5

# Notion Database IDs (se llenan después del setup)
NOTION_STORES_DATABASE_ID=
NOTION_EMAILS_DATABASE_ID=
NOTION_STATS_DATABASE_ID=
NOTION_DASHBOARD_ID=
